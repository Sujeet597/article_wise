<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <webSocket enabled="true" />
    <handlers>
      <add name="PythonHandler" path="*" verb="*" modules="httpPlatformHandler" resourceType="Unspecified" />
    </handlers>
    <httpPlatform processPath="python" arguments="-m streamlit.cli run streamlit_app.py --server.port=%HTTP_PLATFORM_PORT% --server.address=0.0.0.0">
      <environmentVariables>
        <environmentVariable name="PYTHONPATH" value="%APP_BASE_PATH%" />
        <environmentVariable name="STREAMLIT_SERVER_HEADLESS" value="true" />
        <environmentVariable name="STREAMLIT_CLIENT_TOOLBAR_MODE" value="minimal" />
        <environmentVariable name="PYTHONUNBUFFERED" value="1" />
      </environmentVariables>
    </httpPlatform>
    
    <!-- Rewrite rules for proper routing -->
    <rewrite>
      <rules>
        <rule name="Redirect to https" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTPS}" pattern="^OFF$" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}{REQUEST_URI}" redirectType="Permanent" />
        </rule>
      </rules>
    </rewrite>

    <!-- Remove request limits for file uploads -->
    <security>
      <requestFiltering>
        <requestLimits maxUrl="4096" maxQueryString="2048" maxAllowedContentLength="209715200" />
      </requestFiltering>
    </security>

    <!-- Compression -->
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />

    <!-- Headers -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-XSS-Protection" value="1; mode=block" />
      </customHeaders>
    </httpProtocol>

    <!-- CORS for local development -->
    <cors enabled="false" />

  </system.webServer>

  <appSettings>
    <!-- Streamlit settings -->
    <add key="STREAMLIT_SERVER_PORT" value="8000" />
    <add key="STREAMLIT_SERVER_ADDRESS" value="0.0.0.0" />
    <add key="STREAMLIT_SERVER_HEADLESS" value="true" />
  </appSettings>

</configuration>
